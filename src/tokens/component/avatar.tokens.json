{
  "avatar": {
    "size": {
      "sm": { "$value": "{size.5}", "$type": "dimension" },
      "md": { "$value": "{size.10}", "$type": "dimension" },
      "lg": { "$value": "{size.20}", "$type": "dimension" }
    },
    "shape": {
      "circular": { "$value": "{radius.full}", "$type": "dimension" },
      "rounded": { "$value": "{radius.lg}", "$type": "dimension" },
      "square": { "$value": "{radius.md}", "$type": "dimension" }
    },
    "fontSize": {
      "sm": { "$value": "{font.size.md}", "$type": "dimension" },
      "md": { "$value": "{font.size.lg}", "$type": "dimension" },
      "lg": { "$value": "{font.size.xl}", "$type": "dimension" }
    },
    "bg": {
      "default": { "$value": "{color.neutral.200}", "$type": "color" }
    },
    "fg": {
      "default": { "$value": "{color.neutral.800}", "$type": "color" }
    }
  }
}
